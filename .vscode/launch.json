{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug SSO Demo",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": ["${workspaceFolder}/packages/file-storage/demos/sso/server.ts"],
      "cwd": "${workspaceFolder}/packages/file-storage/demos/sso",
      "env": {
        "NODE_ENV": "development"
      },
      "envFile": "${workspaceFolder}/packages/file-storage/demos/sso/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
